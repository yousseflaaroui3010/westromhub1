# ============================================================
# FRONTEND env vars (root .env or .env.local)
# ============================================================

# API base URL — only needed when running frontend independently of the proxy.
# With Vite dev server the proxy handles /api automatically; leave this unset.
# VITE_API_BASE_URL=http://localhost:3001

# ============================================================
# API env vars (api/.env)
# ============================================================

PORT=3001

# SEC-1: CORS — exact frontend domain(s), comma-separated. Never use * in production.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ----------------------------------------------------------------
# PRIMARY AI provider — Google Gemini (handles BOTH text & vision)
# Free tier: ai.google.dev/gemini-api  →  New project → API key
# Recommended model: gemini-2.5-flash (fast, multimodal, generous quota)
# ----------------------------------------------------------------
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# ----------------------------------------------------------------
# TEXT fallback — Groq (OpenAI-compatible, very fast inference)
# Free tier: console.groq.com
# ----------------------------------------------------------------
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# ----------------------------------------------------------------
# VISION fallback — OpenRouter (routes to many cloud vision models)
# Free tier: openrouter.ai
# ----------------------------------------------------------------
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-flash-1.5-8b

# ----------------------------------------------------------------
# LOCAL model — Ollama (Docker Compose only, set automatically)
# docker-compose.yml sets OLLAMA_ENABLED=true and pulls gemma4:e4b.
# Do NOT set on Railway — no GPU/enough RAM there.
# ----------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
# gemma4:e4b = 4B params, natively multimodal (text + vision), ~6GB RAM
# gemma4:e12b = 12B params, higher quality, ~16GB RAM
VISION_MODEL=gemma4:e4b
TEXT_MODEL=gemma4:e4b
# OLLAMA_ENABLED=true

# ----------------------------------------------------------------
# FUTURE providers (add your own as needed — see api/src/providers/)
# These follow the same OpenAI-compatible pattern as Groq.
# ----------------------------------------------------------------
# MoonShot (Kimi): https://platform.moonshot.cn/
# MOONSHOT_API_KEY=
# MoonShot base URL: https://api.moonshot.cn/v1
# Models: moonshot-v1-8k | moonshot-v1-32k | moonshot-v1-128k
