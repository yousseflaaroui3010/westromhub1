# Ollama server URL (default: http://localhost:11434)
# Change this if Ollama is running on a different host or port.
VITE_OLLAMA_BASE_URL=http://localhost:11434

# Vision model used for document extraction (PDF/image → structured JSON)
# Recommended: qwen2-vl:7b (strong OCR and layout understanding)
# Alternatives: minicpm-v, llava:13b, gemma3:12b
# Pull with: ollama pull qwen2-vl:7b
VITE_OLLAMA_VISION_MODEL=qwen2-vl:7b

# Text model used for recommendation generation
# Recommended: qwen2.5:7b (fast, instruction-following, HTML output)
# Alternatives: llama3.2:3b (faster/smaller), mistral:7b
# Pull with: ollama pull qwen2.5:7b
VITE_OLLAMA_TEXT_MODEL=qwen2.5:7b
