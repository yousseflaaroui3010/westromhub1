# === FRONTEND ===
# API Base URL (default: /api when running with proxy)
# Change this if running frontend separately from the backend during development.
VITE_API_BASE_URL=http://localhost:3001/api

# === API (api/.env) ===
PORT=3001
OLLAMA_BASE_URL=http://localhost:11434
VISION_MODEL=qwen2-vl:7b
TEXT_MODEL=qwen2.5:7b

# SEC-1: Comma-separated list of allowed CORS origins.
# In production, set this to your exact frontend domain (e.g., https://app.westrom.com).
# Never use * in production.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# AI providers (cloud-first — Groq for text, OpenRouter for vision).
# Required for Railway/cloud deployment. Free tiers available.
#   Groq:        console.groq.com
#   OpenRouter:  openrouter.ai
GROQ_API_KEY=
OPENROUTER_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_MODEL=google/gemini-flash-1.5-8b

# Set OLLAMA_ENABLED=true to include local Ollama in the provider chain.
# Only useful for local Docker Compose (docker-compose.yml sets this automatically).
# Never set this on Railway — Ollama is not available there.
# OLLAMA_ENABLED=true
